MARKET_DATA_PROVIDER=dhan
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_ACCESS_TOKEN=your_dhan_access_token

# Defaults match Dhan index option-chain usage, but keep these overrideable.
DHAN_NIFTY_SECURITY_ID=13
DHAN_NIFTY_SEGMENT=IDX_I
DHAN_BANKNIFTY_SECURITY_ID=25
DHAN_BANKNIFTY_SEGMENT=IDX_I
DHAN_FINNIFTY_SECURITY_ID=27
DHAN_FINNIFTY_SEGMENT=IDX_I

# Number of strikes to keep on each side of ATM in API responses.
DHAN_OPTION_STRIKE_RANGE=20
